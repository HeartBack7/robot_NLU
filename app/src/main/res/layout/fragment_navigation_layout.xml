<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="8dp">

    <!-- 语音/NLU 测试区（复用 NluTestFragment 的交互形态） -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/et_navigation_point"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:background="#33FFFFFF"
            android:hint="开发点"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:singleLine="true"
            android:textSize="14sp" />

        <Button
            android:id="@+id/start_navigation"
            style="@style/TextStyle"
            android:layout_width="50dp"
            android:layout_height="30dp"
            android:layout_marginLeft="8dp"
            android:background="#4CAF50"
            android:text="@string/navigation" />

        <Button
            android:id="@+id/stop_navigation"
            style="@style/TextStyle"
            android:layout_width="50dp"
            android:layout_height="30dp"
            android:layout_marginLeft="8dp"
            android:background="#F44336"
            android:text="@string/navigation_stop" />

        <Button
            android:id="@+id/turn_direction"
            style="@style/TextStyle"
            android:layout_width="80dp"
            android:layout_height="30dp"
            android:layout_marginLeft="8dp"
            android:text="@string/navigation_resume_direction" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="#33FFFFFF" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/et_nav_nlu_input"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:background="#33FFFFFF"
            android:hint="@string/nlu_input_hint"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:singleLine="true"
            android:textColor="#FFFFFF"
            android:textColorHint="#80FFFFFF"
            android:textSize="14sp" />

        <Button
            android:id="@+id/btn_nav_voice_input"
            android:layout_width="80dp"
            android:layout_height="30dp"
            android:layout_marginStart="4dp"
            android:background="#9E9E9E"
            android:text="@string/nlu_voice_input_off"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_nav_nlu_query"
            android:layout_width="50dp"
            android:layout_height="30dp"
            android:layout_marginStart="4dp"
            android:background="#4CAF50"
            android:text="@string/nlu_query"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />

        <Button
            android:id="@+id/btn_nav_nlu_clear"
            android:layout_width="50dp"
            android:layout_height="30dp"
            android:layout_marginStart="4dp"
            android:background="#757575"
            android:text="@string/nlu_clear"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_nav_voice_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:background="#1AFFFFFF"
        android:padding="6dp"
        android:text="@string/nlu_voice_waiting"
        android:textColor="#B0BEC5"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="Domain:"
            android:textColor="#FFD54F"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_nav_domain"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="--"
            android:textColor="#FFFFFF"
            android:textIsSelectable="true"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="Intent:"
            android:textColor="#4FC3F7"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_nav_intent"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="--"
            android:textColor="#FFFFFF"
            android:textIsSelectable="true"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:text="Dest:"
            android:textColor="#81C784"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_nav_destination"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="--"
            android:textColor="#FFFFFF"
            android:textIsSelectable="true"
            android:textSize="13sp" />
    </LinearLayout>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/nlu_raw_response"
        android:textColor="#80FFFFFF"
        android:textSize="11sp" />

    <TextView
        android:id="@+id/tv_nav_raw_result"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:background="#1AFFFFFF"
        android:padding="6dp"
        android:text="--"
        android:textColor="#B0BEC5"
        android:textIsSelectable="true"
        android:textSize="11sp" />

</LinearLayout>
